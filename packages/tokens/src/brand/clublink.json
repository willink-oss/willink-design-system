{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "ClubLink — 地域クラブ × 応援者マーケットプレイス。blue + green 主軸",
  "brand": "clublink",
  "color": {
    "brand":        { "$value": "#2563eb", "$type": "color", "$description": "blue-600" },
    "brand-fg":     { "$value": "#ffffff", "$type": "color" },
    "brand-glow":   { "$value": "#3b82f6", "$type": "color", "$description": "blue-500" },
    "accent-cyan":  { "$value": "#10b981", "$type": "color", "$description": "ClubLink は cyan ではなく green-500 (sport feel)" },
    "accent-pink":  { "$value": "#059669", "$type": "color", "$description": "ClubLink は pink ではなく green-600 (sport feel)" }
  },
  "gradient": {
    "subtle":  { "$value": "linear-gradient(to right bottom, #ffffff, #eff6ff, #ecfdf5)", "$type": "gradient" },
    "primary": { "$value": "linear-gradient(135deg, #2563eb 0%, #059669 100%)",          "$type": "gradient" },
    "ai":      { "$value": "linear-gradient(135deg, #10b981 0%, #2563eb 50%, #1d4ed8 100%)", "$type": "gradient" }
  }
}
