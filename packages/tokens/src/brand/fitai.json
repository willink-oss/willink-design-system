{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "fit-ai — AI fitness coaching app。blue + emerald (custom). Flutter brand_axis.dart の WillinkBrand.fitai と整合 (primary=#3B82F6 / secondary=#5CDCA8 / tertiary=#8B5CF6).",
  "brand": "fitai",
  "color": {
    "brand":        { "$value": "#3b82f6", "$type": "color", "$description": "blue-500 (fitaiPrimary・Material 3 ColorScheme.primary)" },
    "brand-fg":     { "$value": "#ffffff", "$type": "color" },
    "brand-glow":   { "$value": "#60a5fa", "$type": "color", "$description": "blue-400 (一段薄い tint で glow shadow base)" },
    "accent-cyan":  { "$value": "#5cdca8", "$type": "color", "$description": "fitaiSecondary — fit-ai 独自 emerald (sport feel・shared palette には無し)" },
    "accent-pink":  { "$value": "#8b5cf6", "$type": "color", "$description": "fitaiTertiary — brand-500 violet (cross-brand AI accent)" }
  },
  "gradient": {
    "subtle":  { "$value": "linear-gradient(to right bottom, #ffffff, #eff6ff, #ecfdf5)",            "$type": "gradient", "$description": "white → blue-50 → green-50" },
    "primary": { "$value": "linear-gradient(135deg, #3b82f6 0%, #5cdca8 100%)",                       "$type": "gradient", "$description": "blue-500 → fitai-emerald" },
    "ai":      { "$value": "linear-gradient(135deg, #5cdca8 0%, #3b82f6 50%, #8b5cf6 100%)",          "$type": "gradient", "$description": "emerald → blue → violet (AI tech)" }
  }
}
