{
  "name": "@willink-labs/css-tokens",
  "version": "1.9.0",
  "description": "Framework-agnostic CSS variables export of i-Willink Design System tokens — for plain CSS / Astro / Vue / Svelte / WordPress consumers that don't use the Tailwind preset",
  "license": "MIT",
  "private": false,
  "type": "module",
  "exports": {
    "./tokens.css": "./tokens.css",
    "./tokens.semantic.css": "./tokens.semantic.css",
    "./tokens.scale.css": "./tokens.scale.css",
    "./tokens.dark.css": "./tokens.dark.css",
    "./tokens.primitives.css": "./tokens.primitives.css",
    "./src/*.css": "./src/*.css"
  },
  "files": [
    "src",
    "tokens.css",
    "tokens.semantic.css",
    "tokens.scale.css",
    "tokens.dark.css",
    "tokens.primitives.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "build": "node scripts/generate.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@willink-labs/tokens": "workspace:*",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/willink-oss/willink-design-system.git",
    "directory": "packages/css-tokens"
  },
  "homepage": "https://github.com/willink-oss/willink-design-system/tree/main/packages/css-tokens#readme",
  "bugs": {
    "url": "https://github.com/willink-oss/willink-design-system/issues"
  }
}
