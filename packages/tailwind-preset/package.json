{
  "name": "@willink-labs/tailwind-preset",
  "version": "1.9.0",
  "description": "Tailwind v4 preset for i-Willink Design System. Single-brand baseline (willink); consumers customize via CSS variables override on :root.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./preset.css": "./src/preset.css",
    "./safelist.css": "./src/safelist.css"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo \"tailwind-preset: CSS only, no build step required\""
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/willink-oss/willink-design-system.git",
    "directory": "packages/tailwind-preset"
  },
  "homepage": "https://github.com/willink-oss/willink-design-system/tree/main/packages/tailwind-preset#readme",
  "bugs": {
    "url": "https://github.com/willink-oss/willink-design-system/issues"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
