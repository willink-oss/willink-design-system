{
  "name": "@willink-labs/tailwind-preset",
  "version": "0.2.1",
  "description": "Tailwind v4 preset for i-Willink Design System. Imports tokens via @theme and switches brand axes via [data-brand=...] selectors.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./preset.css": "./src/preset.css",
    "./brands/willink.css": "./src/brands/willink.css",
    "./brands/clublink.css": "./src/brands/clublink.css"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "echo \"tailwind-preset: CSS only, no build step required\""
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/willink-labs/willink-design-system.git",
    "directory": "packages/tailwind-preset"
  }
}
